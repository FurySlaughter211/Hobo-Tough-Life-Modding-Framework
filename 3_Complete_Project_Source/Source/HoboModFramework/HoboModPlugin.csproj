<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>HoboModPlugin</AssemblyName>
    <Version>1.0.0</Version>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!-- BepInEx IL2CPP References -->
  <ItemGroup>
    <Reference Include="BepInEx.Core">
      <HintPath>lib\BepInEx.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BepInEx.Unity.IL2CPP">
      <HintPath>lib\BepInEx.Unity.IL2CPP.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>lib\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Il2CppInterop.Runtime">
      <HintPath>lib\Il2CppInterop.Runtime.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- IL2CPP System assemblies -->
    <Reference Include="Il2Cppmscorlib">
      <HintPath>lib\Il2Cppmscorlib.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Il2CppSystem">
      <HintPath>lib\Il2CppSystem.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- Unity References -->
    <Reference Include="UnityEngine">
      <HintPath>lib\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>lib\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>lib\UnityEngine.InputLegacyModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- Game Assembly -->
    <Reference Include="Assembly-CSharp">
      <HintPath>lib\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Assembly-CSharp-firstpass">
      <HintPath>lib\Assembly-CSharp-firstpass.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- TextMeshPro for UI text manipulation -->
    <Reference Include="Unity.TextMeshPro">
      <HintPath>lib\Unity.TextMeshPro.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- UnityEngine.UI for UI components -->
    <Reference Include="UnityEngine.UI">
      <HintPath>lib\UnityEngine.UI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- ImageConversion for loading PNGs -->
    <Reference Include="UnityEngine.ImageConversionModule">
      <HintPath>lib\UnityEngine.ImageConversionModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- AudioModule for audio clip support -->
    <Reference Include="UnityEngine.AudioModule">
      <HintPath>lib\UnityEngine.AudioModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- Unity Addressables for Phase 2 Asset Override System -->
    <Reference Include="Unity.Addressables">
      <HintPath>lib\Unity.Addressables.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Unity.ResourceManager">
      <HintPath>lib\Unity.ResourceManager.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- AssetBundle loading for model replacement -->
    <Reference Include="UnityEngine.AssetBundleModule">
      <HintPath>lib\UnityEngine.AssetBundleModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    
    <!-- Animation/Avatar retargeting support -->
    <Reference Include="UnityEngine.AnimationModule">
      <HintPath>lib\UnityEngine.AnimationModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  
  <!-- NuGet Packages -->
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Microsoft.Unity.Analyzers" Version="1.19.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  

  
  <!-- Copy Assets folder to output -->
  <ItemGroup>
    <Content Include="Assets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <Target Name="PostBuild" AfterTargets="Build" Condition=" '$(OS)' == 'Windows_NT' ">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$env:ConfigurationName='$(ConfigurationName)'; $env:TargetDir='$(TargetDir)'; $env:TargetPath='$(TargetPath)'; if($env:ConfigurationName -notlike '*Debug*'){Write-Host 'Not Debug build, skipping.'; exit 0}; Write-Host '--- Starting Post-Build Deployment ---'; $steam=(Get-ItemProperty 'HKCU:\Software\Valve\Steam').SteamPath; $libs=@($steam); $libs+=((Select-String -Path \&quot;$steam\steamapps\libraryfolders.vdf\&quot; -Pattern '\&quot;path\&quot;' | ForEach-Object { ($_ -replace '.*\&quot;path\&quot;\s+\&quot;','' -replace '\&quot;','').Trim() })); $gamePath=$null; foreach($lib in $libs){ $manifest=Join-Path $lib 'steamapps\appmanifest_632300.acf'; if(Test-Path $manifest){ $inst=(Select-String -Path $manifest -Pattern '\&quot;installdir\&quot;' | ForEach-Object { ($_ -replace '.*\&quot;installdir\&quot;\s+\&quot;','' -replace '\&quot;','').Trim() }); $gamePath=Join-Path $lib \&quot;steamapps\common\$inst\&quot;; break } }; if(-not $gamePath){Write-Host 'Error: Hobo: Tough Life not found'; exit 1}; Write-Host \&quot;Found game at: $gamePath\&quot;; $pluginDir=Join-Path $gamePath 'BepInEx\plugins'; New-Item -ItemType Directory -Force -Path $pluginDir | Out-Null; Write-Host 'Deploying DLLs to BepInEx...'; Copy-Item -Path \&quot;$env:TargetPath\&quot; -Destination (Join-Path $pluginDir 'HoboModPlugin.dll') -Force; $jsonDll=Join-Path $env:TargetDir 'Newtonsoft.Json.dll'; if(Test-Path $jsonDll){ Copy-Item -Path $jsonDll -Destination $pluginDir -Force; Write-Host 'Successfully copied Newtonsoft.Json.dll' } else { Write-Host 'Warning: Newtonsoft.Json.dll not found in build folder' }; Write-Host 'Launch command sent to Steam.'; Start-Process 'steam://run/632300'&quot;" />
  </Target>


</Project>
